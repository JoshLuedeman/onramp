# ============================================================================
# OnRamp Environment Configuration
# Copy to .env and fill in values for production.
# Leave Azure variables empty for dev mode (mock auth, mock AI, SQLite).
# ============================================================================

# ---------- General ----------
# Application name shown in service identification.
ONRAMP_APP_NAME=OnRamp API
# Enable debug mode (verbose logging)
ONRAMP_DEBUG=false

# ---------- Database ----------
# Connection string. Leave empty to run without configured DB persistence.
# For dev SQLite persistence, set: sqlite+aiosqlite:///./onramp_dev.db
# Production example: mssql+aioodbc://user:pass@host/dbname?driver=ODBC+Driver+18+for+SQL+Server
ONRAMP_DATABASE_URL=

# SQL Server SA password (used by docker-compose db service)
MSSQL_SA_PASSWORD=<generate-a-strong-password>

# ---------- Azure Entra ID / Authentication ----------
# Leave ALL empty for dev mode (mock auth).
# When both tenant and client IDs are set, production mode activates.
ONRAMP_AZURE_TENANT_ID=
ONRAMP_AZURE_CLIENT_ID=
ONRAMP_AZURE_CLIENT_SECRET=

# ---------- Azure AI Foundry ----------
# Leave empty for mock AI responses in dev mode.
ONRAMP_AI_FOUNDRY_ENDPOINT=
ONRAMP_AI_FOUNDRY_KEY=
ONRAMP_AI_FOUNDRY_DEPLOYMENT=
ONRAMP_AI_FOUNDRY_MODEL=gpt-4o

# ---------- CORS ----------
# Allowed origins as a JSON array (Pydantic parses list[str] from JSON).
ONRAMP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------- Security ----------
# Content Security Policy override (empty = use built-in dev/prod default).
ONRAMP_CSP_POLICY=

# Rate limiting (requests per minute). Disabled in dev mode.
ONRAMP_RATE_LIMIT_DEFAULT=60
ONRAMP_RATE_LIMIT_AI=5
ONRAMP_RATE_LIMIT_DEPLOY=3
